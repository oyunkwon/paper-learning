# paper-learning 환경변수 예시. Coolify의 Environment Variables UI에 설정한다
# (이 파일은 커밋하되 실제 값은 넣지 않는다).

# --- Postgres (compose 내부 네트워크) ---
POSTGRES_USER=paper
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=paper_learning

# --- LLM relay (필수) ---
RELAY_API_KEY=
RELAY_BASE_URL=https://relay.algorix.io/v1
LLM_MODEL=claude-opus-4.8

# --- 외부 retrieval (OpenAlex polite pool용 연락 이메일 권장) ---
CONTACT_EMAIL=you@company.com

# --- Cloudflare R2 (비우면 cache-only: 볼륨에만 저장) ---
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_REGION=auto

# --- 인증 (Google OAuth + 서명 쿠키) ---
# prod에선 Google 두 값 + redirect URI + session secret 필수.
# 둘 다 비우면 로그인 비활성(아무도 못 들어옴). AUTH_DEV_BYPASS는 GOOGLE_CLIENT_ID가
# 있으면 강제 무시된다.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=https://paper.your-domain.com/api/auth/callback
SESSION_SECRET=
POST_LOGIN_REDIRECT=/
AUTH_DEV_BYPASS=0
